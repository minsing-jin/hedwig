#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
LOCAL_OMX="$ROOT/.tools/omx/node_modules/.bin/omx"

if [ ! -x "$LOCAL_OMX" ]; then
  echo "Local oh-my-codex install not found." >&2
  echo "Run: bash \"$ROOT/scripts/setup-codex-local.sh\"" >&2
  exit 1
fi

if [ -n "${HEDWIG_ORIGINAL_HOME:-}" ]; then
  export HOME="$HEDWIG_ORIGINAL_HOME"
fi

export CODEX_HOME="${CODEX_HOME:-$ROOT/.codex}"
export OMX_MCP_WORKDIR_ROOTS="${OMX_MCP_WORKDIR_ROOTS:-$ROOT}"
export PATH="$ROOT/bin:$ROOT/.tools/omx/node_modules/.bin:$PATH"

exec "$LOCAL_OMX" "$@"
