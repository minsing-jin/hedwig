#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
LOCAL_OUROBOROS="$ROOT/.tools/ouroboros-venv/bin/ouroboros"
LOCAL_HOME="$ROOT/.local-home"

if [ ! -x "$LOCAL_OUROBOROS" ]; then
  echo "Local ouroboros install not found." >&2
  echo "Run: bash \"$ROOT/scripts/setup-codex-local.sh\"" >&2
  exit 1
fi

mkdir -p "$LOCAL_HOME"

export HEDWIG_ORIGINAL_HOME="${HEDWIG_ORIGINAL_HOME:-${HOME:-}}"
export HOME="$LOCAL_HOME"
export OUROBOROS_CLI_PATH="${OUROBOROS_CLI_PATH:-$ROOT/bin/omx}"
export OUROBOROS_CODEX_CLI_PATH="${OUROBOROS_CODEX_CLI_PATH:-$ROOT/bin/omx}"
export OUROBOROS_AGENT_RUNTIME="${OUROBOROS_AGENT_RUNTIME:-codex}"
export PATH="$ROOT/bin:$ROOT/.tools/ouroboros-venv/bin:$ROOT/.tools/omx/node_modules/.bin:$PATH"

exec "$LOCAL_OUROBOROS" "$@"
